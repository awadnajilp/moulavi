{
  "name": "moulavi-erp-backend",
  "version": "1.0.0",
  "description": "Backend API for Moulavi ERP System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon src/server.ts",
    "build": "npx prisma generate && npx tsc",
    "start": "node dist/server.js",
    "migrate": "node -r ts-node/register src/database/migrate.ts",
    "create-admin": "node scripts/create-admin.js",
    "seed-master": "node scripts/seed-all.js",
    "postinstall": "prisma generate",
    "deploy": "npm run build && npm start"
  },
  "keywords": [
    "erp",
    "umrah",
    "visa"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.907.0",
    "@aws-sdk/s3-request-presigner": "^3.907.0",
    "@prisma/client": "^6.17.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "googleapis": "^166.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "puppeteer": "^24.15.0",
    "uuid": "^9.0.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.2",
    "prisma": "^6.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
